<!--メインビジュアルページ-->
<section class="relative bg-amber-100 py-24 overflow-hidden">
  <div class="relative max-w-6xl mx-auto px-6 grid md:grid-cols-2 gap-16 items-center">

    <div class="order-1">
      <h1 class="text-4xl font-bold leading-tight text-shadow-lg">
        あなたの<span class="text-orange-500">「愛」</span>が、<br>
        他の誰かの<span class="text-orange-500">「見たい」</span>に繋げる
      </h1>

      <p class="mt-6 text-gray-700">
        アニメの感想を記録して<br>
        次の「見たい」を生み出そう
      </p>

      <div class="flex mt-8 gap-4">
        <%= link_to "今すぐ始める", new_user_path, class: "text-white bg-orange-500 px-6 py-3 rounded-lg shadow-lg hover:bg-orange-600" %>
        <%= link_to "投稿を見る", posts_path, class: "border border-gray-400 px-6 py-3 rounded-lg shadow-lg bg-amber-200" %>
      </div>
    </div>

    <div class="order-2 md:order-3 rotate-2"> <!--rotate-2は斜めに表示させる-->
      <%= image_tag "formcard.png", class: "rounded-lg" %>
    </div>

    <section class="order-3 md:order-2 py-6 mt-8 bg-white rounded-full shadow-lg">
      <h2 class="text-xl font-bold mb-4 text-center">
        アニメの記録をもっと簡単に
      </h2>

      <div class="grid grid-cols-3 gap-8 text-center">
        <div>
          <div class="mx-auto w-16 h-16 flex items-center justify-center bg-orange-100 rounded-full">
            <%= heroicon "pencil-square", options: { class: "w-8 h-8 text-orange-500" } %>
          </div>
          <h3 class="mt-2 font-semibold text-lg">愛を語る</h3>
          <p class="text-gray-600 text-sm">作品情報は自動取得</p>
        </div>

        <div>
          <div class="mx-auto w-16 h-16 flex items-center justify-center bg-orange-100 rounded-full">
            <%= heroicon "fire", variant: :outline, options: { class: "w-8 h-8 text-orange-500" } %>
          </div>
          <h3 class="mt-2 font-semibold text-lg">熱量で出会う</h3>
          <p class="text-gray-600 text-sm">見たい」で作品発見</p>
        </div>

        <div>
          <div class="mx-auto w-16 h-16 flex items-center justify-center bg-orange-100 rounded-full">
            <%= heroicon "eye", variant: :outline, options: { class: "w-8 h-8 text-orange-500" } %>
          </div>
          <h2 class="mt-2 font-semibold text-lg">一瞬で「みた！」</h2>
          <p class="text-gray-600 text-sm">直感的に記録</p>
        </div>
      </div>
    </section>
  </div>
</section>