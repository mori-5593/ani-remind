<fieldset class="max-w-2xl mx-auto mt-10 p-6 bg-white rounded-lg shadow-md" data-controller="search">

  <%= form_with model: @post, local: true, class: "space-y-6" do |form| %>

    <%= form.hidden_field :annict_id, data: { search_target: "annictId" } %>
    <%= form.hidden_field :image_url, data: { search_target: "imageUrl" } %>
    <%= form.hidden_field :from %>

    <div>
      <%= form.label :title, "アニメ題名", for: "title-search", class: "block text-sm font-medium text-gray-700" %>
      <%= form.text_field :title, 
          id: "title-search", 
          required: true, 
          autocomplete: "off", 
          class: "mt-1 block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500",
          data: { 
            search_target: "input",
            action: "input->search#handleSearch" 
          } %>
      <div id="search-results" 
           class="mt-2 border rounded shadow-md hidden bg-white relative z-50 overflow-hidden"
           data-search-target="results"></div>
    </div>

    <div data-controller="status-visibility">
      <div class="mb-6">
        <%= form.label :status, "視聴状況", class: "block text-sm font-medium text-gray-700" %>
        <%= form.select :status, [["みた", "watched"], ["みたい", "want_to_watch"]], {}, { id: "status-select", class: "form-select", data: { status_visibility_target: "status", action: "change->status-visibility#toggle"} } %>
      </div>

      <div data-status-visibility-target="form">
        <fieldset id="rating-field" class="mb-6">
          <legend class="block text-sm font-medium text-gray-700 mb-1">評価</legend>
          <div class="star_rating flex flex-row-reverse justify-end">
            <% [5, 4, 3, 2, 1].each do |num| %>
              <%= form.radio_button :rating, num, id: "star#{num}", class: "hidden" %>
              <%= form.label :rating, "★", for: "star#{num}", class: "text-2xl text-gray-300 cursor-pointer peer-checked:text-yellow-400 hover:text-yellow-400 transition-colors" %>
            <% end %>
          </div>
        </fieldset>

        <div>
          <%= form.label :content, "感想", class: "block text-sm font-medium text-gray-700" %>
          <%= form.text_area :content, rows: 5, class: "mt-1 block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500" %>
        </div>
      </div>
    </div>

    <%= form.submit post.new_record? ? "投稿する" : "更新する" , class: "w-full mt-4 flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none transition-colors" %>
  <% end %>
</fieldset>
