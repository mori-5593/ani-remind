<div class="container mx-auto px-4 py-8">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold mb-6"><%= @page_title %></h1>
    <div class="mb-6 p-4 bg-gray-50 rounded shadow-sm">
      <%= search_form_for @q do |form| %>
        <div class="flex gap-2">
          <%= form.search_field :title_cont, placeholder: "タイトルで検索", class: "border rounded px-2 py-1" %>
          <%= form.submit "検索", class: "bg-indigo-600 text-white px-4 py-1 rounded" %>
          <%= link_to "クリア", posts_path, class: "bg-gray-400 text-white px-4 py-1 rounded" %>
        </div>
      <% end %>
    </div>
  </div>

  <% if @posts.any? %>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <%= render partial: 'post', collection: @posts, as: :post %>
    </div>
  <% else %>
    <div class="text-center py-10">
      <p class="text-gray-500">まだ投稿がありません。お気に入りの作品を登録しましょう！</p>
      <%= link_to "投稿する", new_post_path, class: "text-blue-500 hover:underline mt-2 block" %>
    </div>
  <% end %>

<% if @pagy.pages > 1 %>
  <div class="mt-10 flex justify-center">
    <div class="flex items-center gap-2">

      <% if @pagy.prev %>
        <%= link_to "← 前", url_for(page: @pagy.prev),
          class: "px-3 py-1 bg-white border rounded border-gray-100 hover:bg-gray-100",
          data: { turbo_frame: "posts-container" } %>
      <% end %>

      <span class="text-sm text-gray-500">
        <%= @pagy.page %> / <%= @pagy.pages %>
      </span>

      <% if @pagy.next %>
        <%= link_to "次 →", url_for(page: @pagy.next),
          class: "px-3 py-1 bg-white border rounded border-gray-100 hover:bg-gray-100",
          data: { turbo_frame: "posts-container" } %>
      <% end %>

    </div>
  </div>
<% end %></div>