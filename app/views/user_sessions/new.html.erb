<div class="flex min-h-full flex-col justify-center px-6 py-10 lg:px-8">
  <div class="sm:mx-auto sm:w-full sm:max-w-sm">
    <h1 class="mt-4 text-center text-2xl font-bold leading-9 tracking-tight text-gray-900">ログイン</h1>
  </div>

  <div class="mt-4 sm:mx-auto sm:w-full sm:max-w-sm p-8 bg-white shadow-md rounded-lg">
    <%= form_with url: login_path, class: "space-y-6" do |form| %>
      <div>
        <%= form.label :email_address, "メールアドレス", class: "block text-sm font-medium leading-6 text-gray-900" %>
        <%= form.email_field :email_address, required: true, class: "block w-full rounded-md border-0 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm sm:leading-6 p-2" %>
      </div>

      <div>
        <%= form.label :password, "パスワード", class: "block text-sm font-medium leading-6 text-gray-900" %>
        <%= form.password_field :password, required: true, class: "block w-full rounded-md border-0 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm sm:leading-6 p-2" %>
      </div>

      <%= form.label :remember_me do %>
        <%= form.check_box :remember_me %>
        <span>ログイン情報を記憶する</span>
      <% end %>

      <div>
        <%= form.submit "ログイン", class: "flex w-full justify-center rounded-md bg-indigo-600 px-3 py-1.5 text-sm font-semibold leading-6 text-white shadow-sm mt-4 hover:bg-indigo-500 transition-colors" %>
      </div>
    <% end %>

    <p class="mt-4 text-center text-sm text-gray-500">アカウントをお持ちでないですか？<br>
      <%= link_to "新規登録はこちら", new_user_path, class: "font-semibold leading-6 text-indigo-600 hover:text-indigo-500" %>
    </p>

    <div class="border-t border-gray-400 mt-4"></div>
    <div class="flex flex-col items-center gap-4 py-6">
      <%= button_to "/auth/google_oauth2", method: :post, data: { turbo: false }, class: "flex items-center justify-center gap-3 w-72 py-3 bg-white border border-gray-300 rounded-xl shadow-sm hover:shadow-md transition" do %>
        <img src="https://www.svgrepo.com/show/475656/google-color.svg" class="w-5 h-5">
        <span class="text-gray-700 font-medium">Googleでログイン</span>
      <% end %>
      <%= button_to "/auth/line", method: :post, data: { turbo: false }, class: "flex items-center justify-center gap-3 w-72 px-4 py-3 bg-green-500 text-white rounded-xl shadow-sm hover:shadow-md transition" do %>
        <%= image_tag "line_icon.png", class: "w-7 h-7" %>
        <span class="font-medium">LINEでログイン</span>
      <% end %>
    </div>
  </div>
</div>