<div class="flex min-h-full flex-col justify-center px-6 py-10 lg:px-8">
  <div class="sm:mx-auto sm:w-full sm:max-w-sm">
    <h1 class="text-center text-2xl font-bold leading-9 tracking-tight text-gray-900">新規登録</h1>
  </div>

  <div class="mt-4 sm:mx-auto sm:w-full sm:max-w-sm p-8 bg-white shadow-md rounded-lg">
    <%= form_with model: @user, class: "space-y-4" do |form| %>
      <% if @user.errors.any? %>
        <div style="color: red">
          <h2><%= pluralize(@user.errors.count, "個のエラー") %>により登録できませんでした：</h2>
          <ul>
            <% @user.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div>
        <%= form.label :name, "名前", class: "block text-sm font-medium leading-6 text-gray-900" %>
        <%= form.text_field :name, required: true, class: "block w-full rounded-md border-0 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm sm:leading-6 p-2" %>
      </div>

      <div>
        <%= form.label :email_address, "メールアドレス", class: "block text-sm font-medium leading-6 text-gray-900" %>
        <%= form.email_field :email_address, required: true, autofocus: true, class: "block w-full rounded-md border-0 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm sm:leading-6 p-2" %>
      </div>

      <div>
        <%= form.label :password, "パスワード", class: "block text-sm font-medium leading-6 text-gray-900" %>
        <%= form.password_field :password, required: true, class: "block w-full rounded-md border-0 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm sm:leading-6 p-2" %>
      </div>

      <div>
        <%= form.label :password_confirmation, "パスワード（確認用）", class: "block text-sm font-medium leading-6 text-gray-900" %>
        <%= form.password_field :password_confirmation, required: true, class: "block w-full rounded-md border-0 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm sm:leading-6 p-2" %>
      </div>

      <br>

      <div>
        <%= form.submit "登録する", class: "flex w-full justify-center rounded-md bg-indigo-600 px-3 py-1.5 text-sm font-semibold leading-6 text-white shadow-sm hover:bg-indigo-500 transition-colors" %>
      </div>
    <% end %>

    <p class="mt-4 text-center text-sm text-gray-500">すでにアカウントをお持ちですか？<br>
      <%= link_to "ログインはこちら", login_path, class: "font-semibold leading-6 text-indigo-600 hover:text-indigo-500" %>
    </p>

    <div class="border-t border-gray-400 mt-4"></div>
    <div class="flex flex-col items-center gap-4 py-6">
      <%= button_to "/auth/google_oauth2", method: :post, data: { turbo: false }, class: "flex items-center justify-center gap-3 w-72 py-3 bg-white border border-gray-300 rounded-xl shadow-sm hover:shadow-md transition" do %>
        <img src="https://www.svgrepo.com/show/475656/google-color.svg" class="w-5 h-5">
        <span class="text-gray-700 font-medium">Googleでログイン</span>
      <% end %>
      <%= button_to "/auth/line", method: :post, data: { turbo: false }, class: "flex items-center justify-center gap-3 w-72 px-4 py-3 bg-green-500 text-white rounded-xl shadow-sm hover:shadow-md transition" do %>
        <%= image_tag "line_icon.png", class: "w-7 h-7" %>
        <span class="font-medium">LINEでログイン</span>
      <% end %>
    </div>
  </div>
</div>