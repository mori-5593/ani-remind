<h1 class="text-2xl font-bold text-center my-8"><%= @user.name || "名無しさん" %>のマイページ</h1>
<!--自己紹介部分-->
<div class="max-w-5xl mx-auto px-4 py-8">
  <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6 mb-8">
    <div class="flex items-center justify-between mb-4">
      <div class="flex items-center gap-4">
        <div class="w-20 h-20 bg-blue-100 rounded-full flex items-center justify-center text-blue-500 text-2xl font-bold">
          <!-- <%= @user.name %> -->
        </div>
        <div>
          <h1 class="text-xl font-bold text-gray-800"><%= @user.name || "名無しさん" %></h1>
          <p class="bor-t border-gray-100 text-gray-600"><%= @user.introduction && @user.introduction.present? ? @user.introduction : "自己紹介はまだありません" %></p>
        </div>
      </div>

      <% if @user == current_user %>
        <%= link_to "プロフィール編集", edit_user_path(@user), class: "px-4 py-2 bg-gray-100 hover:bg-gray-200 text-gray-700 text-sm font-medium rounded-md transition" %>
      <% end %>
    </div>
  </div>
</div>

<!--ページタブ部分-->
<turbo-frame id="posts-container" class="max-w-5xl mx-auto px-4">
  <div class="flex space-1 border-b border-gray-200 mb-6">
    <%= link_to "全て", user_path(@user), class: "px-4 py-2 text-lg font-semibold #{params[:status].nil? ? 'border-b-2 border-orange-500 text-orange-500' : 'text-gray-500 hover:text-orange-500'}", data: { turbo_frame: "posts-container" } %>
    <%= link_to "みた", user_path(@user, status: 'watched'), class: "px-4 py-2 text-lg font-semibold #{params[:status] == 'watched' ? 'border-b-2 border-orange-500 text-orange-500' : 'text-gray-500 hover:text-orange-500'}", data: { turbo_frame: "posts-container" } %>
    <%= link_to "みたい", user_path(@user, status: 'want_to_watch'), class: "px-4 py-2 text-lg font-semibold #{params[:status] == 'want_to_watch' ? 'border-b-2 border-orange-500 text-orange-600' : 'text-gray-500 hover:text-orange-500'}", data: { turbo_frame: "posts-container" } %>
  </div>

  <div class="max-w-5xl mx-auto px-4">
    <% if params[:status] == 'want_to_watch' %>
      <%# 【A】「みたい」タブが選ばれている時（Actionモデルを表示） %>
      <div class="grid grid-cols-1">
        <% if @want_to_watch_actions.present? && @want_to_watch_actions.any? %>
          <% @want_to_watch_actions.each do |action| %>
            <div class="flex bg-white rounded-lg shadow-sm border border-gray-200 mb-3 h-32 overflow-hidden">
              <%# 画像部分 %>
              <div class="w-1/4 bg-gray-100 flex-shrink-0">
                <% if action.image_url.present? %>
                  <img src="<%= action.image_url %>" class="w-full h-full object-cover">
                <% else %>
                  <div class="flex items-center justify-center w-full h-full text-xs text-gray-400 font-medium">No Image</div>
                <% end %>
              </div>

              <%# テキスト部分 %>
              <div class="w-3/4 p-3 flex flex-col justify-between">
                <h2 class="text-base font-bold text-gray-800"><%= action.title || "タイトル不明" %></h2>
                <p class="italic text-gray-400">見たら感想を書きましょう</p>
                <div class="flex justify-end">
                  <%= render_action_button(action) %>
                </div>
              </div>
            </div>
          <% end %>
        <% else %>
          <p class="text-gray-500 italic">「みたい」作品はまだありません</p>
        <% end %>
      </div>

    <% else %>
      <%# 【B】「全て」または「みた」タブ（Postモデルを表示） %>
      <div class="space-y-4">
        <% items = @items %>

        <% if items.any? %>
          <% items.each do |item| %>
            <div class="flex bg-white rounded-lg shadow-sm border border-gray-200 mb-3 h-32 overflow-hidden">
              <div class="w-1/4 bg-gray-100 flex-shrink-0">
                <% if item.image_url.present? %>
                  <img src="<%= item.image_url %>" class="w-full h-full object-cover">
                <% else %>
                  <div class="flex items-center justify-center w-full h-full text-xs text-gray-400 font-medium">No Image</div>
                <% end %>
              </div>

              <div class="w-3/4 p-3 flex flex-col justify-between">
                <div>
                  <div class="flex justify-between items-center mb-3">
                    <% if item.is_a?(Post) %>
                      <%= link_to post_path(item), class: "truncate mr-2 hover:text-blue-600 transition" do %>
                        <h2 class="text-base font-bold text-gray-800"><%= item.title %></h2>
                      <% end %>
                    <% else %>
                      <h2 class="text-base font-bold text-gray-800"><%= item.title %></h2>
                    <% end %>

                    <div class="flex items-center gap-2 text-xs text-gray-700 flex-shrink-0">
                      <% if item.is_a?(Post) %>
                        <span class="font-medium bg-gray-100 px-2 py-0.5 rounded"><%= item.status_i18n %></span>
                      <% end %>
                      <% if item.is_a?(Post) && item.watched? %>
                        <span>|</span>
                        <span class="text-yellow-500"><%= render_stars(item.rating) %></span>
                      <% end %>
                    </div>
                  </div>

                  <%# 内容の出し分け %>
                  <div class="text-gray-600 line-clamp-2 text-sm mr-8">
                    <% if item.is_a?(Post) %>
                      <%= item.content %>
                    <% else %>
                      <p class="italic text-gray-400">見たら感想を書きましょう</p>
                    <% end %>
                  </div>
                </div>

                <%# ボタン（共通ヘルパーが使えます！） %>
                <div class="flex justify-end">
                  <%= render_action_button(item) %>
                </div>
              </div>
            </div>
          <% end %>
        <% else %>
          <p class="text-gray-500 italic">まだ投稿はありません</p>
        <% end %>
      </div>
    <% end %>

  </div>
  <% if @pagy.pages > 1 %>
  <div class="mt-10 flex justify-center">
    <div class="flex items-center gap-2">

      <% if @pagy.prev %>
        <%= link_to "← 前", url_for(page: @pagy.prev),
          class: "px-3 py-1 bg-white border border-gray-100 rounded hover:bg-gray-100",
          data: { turbo_frame: "posts-container" } %>
      <% end %>

      <span class="text-sm text-gray-500">
        <%= @pagy.page %> / <%= @pagy.pages %>
      </span>

      <% if @pagy.next %>
        <%= link_to "次 →", url_for(page: @pagy.next),
          class: "px-3 py-1 bg-white border border-gray-100 rounded hover:bg-gray-100",
          data: { turbo_frame: "posts-container" } %>
      <% end %>

    </div>
  </div>
  <% end %>
</turbo-frame>