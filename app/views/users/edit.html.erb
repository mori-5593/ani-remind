<div class="max-w-xl mx-auto px-4 py-8">
  <h1 class="text-2xl font-bold mb-6">プロフィール編集</h1>

  <%= form_with model: @user, class: "space-y-6" do |form| %>
    <% if @user.errors.any? %>
      <div class="bg-red-50 text-red-500 p-4 rounded-md">
        <ul>
          <% @user.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= form.label :name, "名前", class: "block text-sm font-medium text-gray-700" %>
      <%= form.text_field :name, class: "bg-white mt-1 block w-full border border-gray-300 rounded-md shadow-sm p-2" %>
    </div>

    <div>
      <%= form.label :introduction, "自己紹介", class: "block text-sm font-medium text-gray-700" %>
      <%= form.text_area :introduction, class: "bg-white mt-1 block w-full border border-gray-300 rounded-md shadow-sm p-2", placeholder: "アニメの好みや一言をどうぞ！" %>
    </div>

    <div>
      <%= form.label :email_address, "メールアドレス", class: "block text-sm font-medium text-gray-700" %>
      <%= form.email_field :email_address, class: "bg-white mt-1 block w-full border border-gray-300 rounded-md shadow-sm p-2" %>
    </div>

    <div class="flex items-center gap-4">
      <%= form.submit "更新する", class: "px-6 py-2 bg-blue-600 text-white rounded-md hover:bg-blue-700 cursor-pointer" %>
      <%= link_to "キャンセル", user_path(@user), class: "text-gray-500 hover:underline" %>
    </div>
  <% end %>
</div>
